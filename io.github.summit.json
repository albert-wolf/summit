{
  "app-id": "io.github.summit",
  "runtime": "org.gnome.Platform",
  "runtime-version": "47",
  "sdk": "org.gnome.Sdk",
  "command": "summit",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=home",
    "--filesystem=xdg-config/gtk-4.0:ro",
    "--talk-name=org.freedesktop.Notifications",
    "--talk-name=org.freedesktop.Flatpak",
    "--talk-name=org.freedesktop.Settings",
    "--metadata=X-DDP-Version=1"
  ],
  "modules": [
    {
      "name": "summit",
      "buildsystem": "simple",
      "build-commands": [
        "glib-compile-resources --target=src/resources/summit.gresource --sourcedir=src src/resources/summit.gresource.xml",
        "mkdir -p /app/share/summit/resources",
        "install -D src/resources/summit.gresource /app/share/summit/resources/summit.gresource",
        "install -D debian/summit.desktop /app/share/applications/io.github.summit.desktop",
        "mkdir -p /app/share/summit/src",
        "cp src/*.py /app/share/summit/src/",
        "mkdir -p /app/bin",
        "echo '#!/bin/sh' > /app/bin/summit",
        "echo 'exec python3 /app/share/summit/src/main.py \"$@\"' >> /app/bin/summit",
        "chmod +x /app/bin/summit"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
